{
  "name": "bare-storage",
  "version": "1.0.0",
  "description": "Minimal, cross-platform directory locator for Bare",
  "exports": {
    "./package": "./package.json",
    ".": "./index.js"
  },
  "files": [
    "index.js",
    "lib",
    "binding.mm",
    "binding.js",
    "CMakeLists.txt",
    "prebuilds"
  ],
  "addon": true,
  "scripts": {
