  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nicolo-ribaudo/bare-storage.git"
  },
  "author": "Holepunch",
  "license": "Apache-2.0",
  "dependencies": {
    "bare-os": "^3.0.0",
    "bare-path": "^3.0.0"
  },
  "devDependencies": {
    "brittle": "^3.4.0",
    "cmake-bare": "^1.1.2",
    "cmake-fetch": "^1.4.9"
  }
}
